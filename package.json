{
  "name": "next-template",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "migrate": "tsx scripts/migrate.ts",
    "lint": "eslint",
    "format": "prettier . --write",
    "typecheck": "next typegen && tsc --noEmit && echo No TypeScript issues",
    "test": "vitest run",
    "validate": "yarn typecheck && yarn lint && yarn format:check && yarn test --coverage",
    "cleanup": "rm -rf .next && rm -rf .swc && rm -rf .test-artifacts && watchman watch-del-all > /dev/null",
    "circular": "npx madge --circular --extensions ts,tsx ./src"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@opentelemetry/api": "^1.9.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.29.2",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "pluralize": "^8.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "inquirer": "^14.0.2",
    "kysely-codegen": "^0.20.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "madge": {
    "detectiveOptions": {
      "ts": {
        "skipTypeImports": true
      }
    }
  }
}
